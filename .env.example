# =============================================================================
# ArchNet Backend — Environment Variable Template
# Copy this file to .env and fill in all values before running the application.
# NEVER commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime Environment
# "development" | "staging" | "production"
# Controls dev-only behaviours (auto dev-user, OTel fallback, etc.)
# ---------------------------------------------------------------------------
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Security — JWT & Session
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# The application will REFUSE to start in non-development mode if this is
# left as the placeholder value.
# ---------------------------------------------------------------------------
SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Database Setup
# Replace <password> with a strong random password.
# The DATABASE_URL must match the POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://mlbuilder:<password>@postgres:5432/mlbuilder_db
POSTGRES_USER=mlbuilder
POSTGRES_PASSWORD=<strong random password>
POSTGRES_DB=mlbuilder_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# Placeholder: replace with your actual production frontend URL(s) before deploying.
# e.g. CORS_ORIGINS=https://archnet.io,https://www.archnet.io
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------------------------
# GCP Vertex AI Webhook Secret
# Shared secret used to authenticate webhook callbacks from training containers.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The application will REFUSE to start in non-development mode if this is empty.
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# ---------------------------------------------------------------------------
# Uvicorn Workers (Docker)
# Number of uvicorn worker processes. Set to (2 * CPU cores + 1) for production.
# ---------------------------------------------------------------------------
WEB_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Grafana Admin Password
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=<strong random password>

# ---------------------------------------------------------------------------
# AWS Storage (Optional — Phase 2: S3 Dataset Upload)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ---------------------------------------------------------------------------
# GCP Storage & Vertex AI Configuration (Optional)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_CREDENTIALS_JSON=

# ---------------------------------------------------------------------------
# LLM API Keys (Optional)
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
