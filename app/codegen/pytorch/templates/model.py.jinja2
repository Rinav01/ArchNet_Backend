import torch
import torch.nn as nn
import torch.nn.functional as F

class MLBuilderModel(nn.Module):
    """
    Generated PyTorch Model from MLBuilder Architecture Canvas.
    Name: {{ project_name }}
    Framework: {{ framework }}
    """
    def __init__(self):
        super(MLBuilderModel, self).__init__()
        
        # Layer Definitions
        {%- for layer in layers_init %}
        self.{{ layer.name }} = {{ layer.pytorch_init }}
        {%- endfor %}

    def forward(self, x):
        # x shape: {{ input_shape_comment }}
        
        # Forward execution flow
        {%- for step in forward_steps %}
        x = self.{{ step.name }}(x)  # shape: {{ step.shape }}
        {%- if step.activation %}
        x = {{ step.activation }}(x)
        {%- endif %}
        {%- endfor %}
        
        return x

